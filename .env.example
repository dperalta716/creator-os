# === API Keys ===
# Copy this file to ~/.env and fill in your keys

# DataForSEO (for keyword research, SERP analysis, Medium search)
# Sign up: https://dataforseo.com/
DATAFORSEO_USER=your-email@example.com
DATAFORSEO_PASS=your-api-password

# Firecrawl (for web scraping competitor articles)
# Sign up: https://firecrawl.dev/
FIRECRAWL_API_KEY=fc-your-key-here

# XAI / Grok (for Twitter/X research via Grok API)
# Sign up: https://console.x.ai/
XAI_API_KEY=your-key-here

# fal.ai (for article image generation)
# Sign up: https://fal.ai/
# Save your key to: .claude/skills/fal-ai/fal-api-key
FAL_KEY=your-key-here
